# Copy this file to .env.local (gitignored) and fill in real values.
# Every var here is OPTIONAL — the corresponding panel/lab degrades
# gracefully when its var is unset (no crashes, just an empty section).

# /homelab and contribution graph — github personal access token with
# public_repo + read:user scopes. classic or fine-grained both work.
GITHUB_TOKEN=

# /music — last.fm api key (no secret needed for public scrobble reads).
LASTFM_API_KEY=

# /labs/pdf-uploader and other R2-backed flows — base URL of your
# public R2 bucket. unset = the lab still works but uploads can't be
# served back.
R2_PUBLIC_URL=

# Used by scripts/lexicons-publish.ts and scripts/guestbook-marker.ts:
# bsky handle + app password (NOT your real password — generate one at
# https://bsky.app/settings/app-passwords). these never reach the
# browser; they only run from local cli scripts.
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# /labs/twitch-live — twitch helix app credentials from
# https://dev.twitch.tv/console. server-side only.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# /guestbook — push-notification bearer token for api.brrr.now. when
# someone signs the guestbook the worker fires a notification to luna's
# phone. unset = guestbook still works, no notification fires.
BRRR_SECRET=

# Snake / sudoku / mahjong / klondike leaderboards — HMAC signing key
# for score submissions. any opaque string. shared between the marker
# script and the worker.
LEADERBOARD_HMAC_SECRET=

# /homelab — HMAC-SHA256 signing key for telemetry pushes from the
# homelab-agent NixOS module (../nixos-configs/modules/homelab-agent.nix).
# shared between the worker and every host's sops:homelab_agent_secret.
# unset = the ingest endpoint returns 503 and the page falls back to its
# editorial defaults.
# generate with: openssl rand -hex 32
# for prod: wrangler secret put HOMELAB_AGENT_SECRET
HOMELAB_AGENT_SECRET=

# /api/status — bearer token authenticating the iOS Shortcuts POST that
# updates the home-page DND / focus pill. Any opaque string; share with
# the iOS Shortcut. unset = the endpoint returns 503 and the home page
# falls back to the static STATUS const in src/data.ts.
# generate with: openssl rand -hex 24
# for prod: wrangler secret put SITE_STATUS_TOKEN
SITE_STATUS_TOKEN=

# /api/health — bearer token for the Health Auto Export iOS app pushing
# Apple Health snapshots (steps, sleep, workouts, etc.) on a schedule.
# unset = endpoint returns 503 and /health falls back to an empty
# state. share between HAE's REST destination and the worker secret.
# generate with: openssl rand -hex 24
# for prod: wrangler secret put HEALTH_TOKEN
HEALTH_TOKEN=

# /playstation — long-lived (~60 day) NPSSO token from your PSN session
# cookies. Grab it once: while signed in to playstation.com, open
# devtools → Application → Cookies → https://ca.account.sony.com →
# copy the value of the `npsso` cookie. Treat as a full-account secret;
# never commit. unset = the /playstation page renders an unconfigured
# state instead of failing.
# for prod: wrangler secret put PSN_NPSSO
PSN_NPSSO=
